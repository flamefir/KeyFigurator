{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KeyFigurator Pro",
  "version": "0.1.0",
  "identifier": "com.macropadpro.config",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "KeyFigurator Pro",
        "width": 1000, "height": 1100,
        "minWidth": 420, "minHeight": 1060,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": { "active": true, "targets": "all" }
}
